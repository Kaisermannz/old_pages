---
interface Props {
    title?: string;
}
const { title = "PORTFOLIO" } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link
            rel="icon"
            href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🖥</text></svg>"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>

        <style is:global>
            /* ═══════════════════════════════════════
         TOKENS
      ═══════════════════════════════════════ */
            :root {
                --bg: #020210;
                --surface: #07071e;
                --surface-2: #0d0d2a;
                --border: #1a1a44;

                /* Neon Orange */
                --orange: #ff6b00;
                --orange-b: #ff8c00;
                --orange-glow:
                    0 0 7px #ff6b00, 0 0 21px #ff4500,
                    0 0 48px rgba(255, 107, 0, 0.35);

                /* Electric Blue */
                --blue: #0077ff;
                --blue-b: #00aaff;
                --blue-glow:
                    0 0 7px #0077ff, 0 0 21px #0044cc,
                    0 0 48px rgba(0, 119, 255, 0.35);

                /* Accents */
                --yellow: #ffd700;
                --green: #00ff88;

                /* Text */
                --text: #eeeeff;
                --muted: #6666aa;

                /* Fonts */
                --font-pixel: "Press Start 2P", monospace;
                --font-vt: "VT323", monospace;
            }

            /* ═══════════════════════════════════════
         RESET
      ═══════════════════════════════════════ */
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }
            html {
                scroll-behavior: smooth;
            }

            /* ═══════════════════════════════════════
         BASE
      ═══════════════════════════════════════ */
            body {
                background: var(--bg);
                color: var(--text);
                font-family: var(--font-vt);
                font-size: 22px;
                line-height: 1.5;
                min-height: 100vh;
                overflow-x: hidden;
            }

            /* ═══════════════════════════════════════
         CUSTOM SCROLLBAR
      ═══════════════════════════════════════ */
            ::-webkit-scrollbar {
                width: 8px;
            }
            ::-webkit-scrollbar-track {
                background: var(--surface);
            }
            ::-webkit-scrollbar-thumb {
                background: linear-gradient(
                    to bottom,
                    var(--orange),
                    var(--blue)
                );
                box-shadow: 0 0 6px var(--orange);
            }

            /* ═══════════════════════════════════════
         STAR BACKGROUND
      ═══════════════════════════════════════ */
            #stars-container {
                position: fixed;
                inset: 0;
                z-index: 0;
                pointer-events: none;
                overflow: hidden;
            }
            .star {
                position: absolute;
                border-radius: 50%;
                background: #fff;
                animation: twinkle ease-in-out infinite;
            }
            @keyframes twinkle {
                0%,
                100% {
                    opacity: 1;
                    transform: scale(1);
                }
                50% {
                    opacity: 0.1;
                    transform: scale(0.5);
                }
            }

            /* ═══════════════════════════════════════
         SITE WRAPPER
      ═══════════════════════════════════════ */
            .site-wrapper {
                position: relative;
                z-index: 1;
                max-width: 900px;
                margin: 0 auto;
                padding: 0 20px 80px;
            }

            /* ═══════════════════════════════════════
         NEON UTILITIES
      ═══════════════════════════════════════ */
            .neon-orange {
                color: var(--orange-b);
                text-shadow: var(--orange-glow);
            }
            .neon-blue {
                color: var(--blue-b);
                text-shadow: var(--blue-glow);
            }
            .neon-yellow {
                color: var(--yellow);
                text-shadow:
                    0 0 7px var(--yellow),
                    0 0 21px rgba(255, 215, 0, 0.5);
            }
            .neon-green {
                color: var(--green);
                text-shadow:
                    0 0 7px var(--green),
                    0 0 21px rgba(0, 255, 136, 0.5);
            }

            /* ═══════════════════════════════════════
         ANIMATIONS
      ═══════════════════════════════════════ */
            .blink {
                animation: blink 1s step-end infinite;
            }
            @keyframes blink {
                0%,
                100% {
                    opacity: 1;
                }
                50% {
                    opacity: 0;
                }
            }

            /* ═══════════════════════════════════════
         DIVIDERS
      ═══════════════════════════════════════ */
            .divider {
                height: 2px;
                background: linear-gradient(
                    90deg,
                    transparent,
                    var(--orange) 30%,
                    var(--blue) 70%,
                    transparent
                );
                margin: 60px 0;
                box-shadow:
                    0 0 10px var(--orange),
                    0 0 20px var(--blue);
            }
            .divider-rainbow {
                height: 4px;
                background: linear-gradient(
                    90deg,
                    #ff0000,
                    #ff6b00,
                    #ffd700,
                    #00ff88,
                    #00aaff,
                    #cc00ff,
                    #ff0000
                );
                margin: 56px 0;
            }

            /* ═══════════════════════════════════════
         PANELS
      ═══════════════════════════════════════ */
            .panel {
                background: var(--surface);
                border: 2px solid var(--border);
                padding: 24px;
            }
            .panel-orange {
                border-color: var(--orange);
                box-shadow:
                    0 0 16px rgba(255, 107, 0, 0.2),
                    inset 0 0 20px rgba(255, 107, 0, 0.03);
            }
            .panel-blue {
                border-color: var(--blue);
                box-shadow:
                    0 0 16px rgba(0, 119, 255, 0.2),
                    inset 0 0 20px rgba(0, 119, 255, 0.03);
            }

            /* ═══════════════════════════════════════
         SECTION TITLES
      ═══════════════════════════════════════ */
            .section-title {
                font-family: var(--font-pixel);
                font-size: 12px;
                letter-spacing: 3px;
                margin-bottom: 36px;
                display: flex;
                align-items: center;
                gap: 16px;
            }
            .section-title::before,
            .section-title::after {
                content: "";
                flex: 1;
                height: 1px;
                background: currentColor;
                opacity: 0.3;
            }

            /* ═══════════════════════════════════════
         LINKS
      ═══════════════════════════════════════ */
            a {
                color: var(--blue-b);
                text-decoration: none;
            }
            a:hover {
                color: var(--orange-b);
                text-decoration: underline;
            }

            /* ═══════════════════════════════════════
         RESPONSIVE
      ═══════════════════════════════════════ */
            @media (max-width: 640px) {
                body {
                    font-size: 20px;
                }
                .section-title {
                    font-size: 9px;
                    letter-spacing: 2px;
                }
                .panel {
                    padding: 16px;
                }
            }
        </style>
    </head>

    <body>
        <!-- Starfield -->
        <div id="stars-container" aria-hidden="true"></div>

        <!-- Page content -->
        <div class="site-wrapper">
            <slot />
        </div>

        <!-- Star generator -->
        <script>
            const container = document.getElementById("stars-container");
            if (container) {
                for (let i = 0; i < 200; i++) {
                    const s = document.createElement("div");
                    s.className = "star";
                    const size = (0.8 + Math.random() * 2.5).toFixed(1);
                    s.style.cssText = [
                        `left:${(Math.random() * 100).toFixed(2)}%`,
                        `top:${(Math.random() * 100).toFixed(2)}%`,
                        `width:${size}px`,
                        `height:${size}px`,
                        `animation-delay:${(Math.random() * 6).toFixed(2)}s`,
                        `animation-duration:${(1.5 + Math.random() * 4).toFixed(2)}s`,
                        `opacity:${(0.3 + Math.random() * 0.7).toFixed(2)}`,
                    ].join(";");
                    container.appendChild(s);
                }
            }
        </script>
    </body>
</html>
